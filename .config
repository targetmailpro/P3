# This is an empty file, please overwrite it after generating the .config file with the source code
CONFIG_TARGET_armvirt=y
CONFIG_TARGET_armvirt_armv7=y          # or CONFIG_TARGET_armvirt_armv8=y for newer
# CONFIG_TARGET_armvirt_armv7 is not set   (commented if using armv8 variant)
CONFIG_TARGET_armvirt_Default=y
# CONFIG_TARGET_armvirt_... (other profiles disabled)

# CPU / Architecture related
CONFIG_ARCH_32BIT=y                    # for armv7
# CONFIG_ARCH_64BIT=y                  # for armv8 / aarch64
CONFIG_CPU_TYPE="cortex-a7"            # or cortex-a53, cortex-a72, etc. depending on selection
# CONFIG_CPU_TYPE_NONE is not set

# Common defaults from Lean/P3TERX template style
CONFIG_ALL_KMODS=y                     # or selective
CONFIG_ALL_PACKAGES=y                  # if you want everything
# or specific packages like luci, ssr-plus, etc.

# Build options
CONFIG_DOWNLOAD_CHECK_CERTIFICATE=n
# etc.
